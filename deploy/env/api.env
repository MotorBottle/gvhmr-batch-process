GVHMR_BATCH_API_APP_ENV=development
GVHMR_BATCH_API_CONTROL_PLANE_BACKEND=postgres+minio
GVHMR_BATCH_API_STORAGE_ROOT=/var/lib/gvhmr-batch-process
GVHMR_BATCH_API_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/gvhmr_batch_process
GVHMR_BATCH_API_MINIO_ENDPOINT=minio:9000
GVHMR_BATCH_API_MINIO_ACCESS_KEY=minioadmin
GVHMR_BATCH_API_MINIO_SECRET_KEY=minioadmin
GVHMR_BATCH_API_MINIO_BUCKET=gvhmr-batch-process
GVHMR_BATCH_API_MINIO_SECURE=false
GVHMR_BATCH_API_WORKER_OFFLINE_AFTER_SECONDS=15
