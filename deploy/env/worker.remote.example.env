# Copy to deploy/env/worker.remote.env on the remote worker host and edit values.
# Use with:
#   make compose-remote-worker-config WORKER_REMOTE_ENV=deploy/env/worker.remote.env
#   make compose-remote-worker-up WORKER_REMOTE_ENV=deploy/env/worker.remote.env
#
# The generalized remote deployment renders one worker container per listed GPU.
# Example:
#   WORKER_GPU_IDS=0,1,2,3

# Compose/image settings
WORKER_IMAGE=gvhmr-batch-process-worker:latest
WORKER_NODE_NAME=worker-bj-02
MODEL_ROOT=/srv/gvhmr-batch-process/models
WORKER_TORCH_CUDA_ARCH_LIST="7.5;8.0;8.6;8.9"

# Generalized one-worker-per-GPU layout.
# Every listed GPU becomes one worker container named:
#   <WORKER_NODE_NAME>-gpu<gpu_slot>
WORKER_GPU_IDS=0,1
WORKER_SCRATCH_ROOT=/srv/gvhmr-batch-process/scratch

# Optional legacy single-worker fallback / explicit overrides.
WORKER_GPU_SLOT=0
WORKER_VISIBLE_DEVICE=0
WORKER_SCRATCH_HOST_PATH=/srv/gvhmr-batch-process/scratch/gpu0

# Optional per-GPU overrides.
# If omitted, each worker uses:
#   NVIDIA_VISIBLE_DEVICES=<gpu_id>
#   scratch path = <WORKER_SCRATCH_ROOT>/gpu<gpu_id>
GPU0_VISIBLE_DEVICE=0
GPU1_VISIBLE_DEVICE=1
GPU0_SCRATCH_HOST_PATH=/srv/gvhmr-batch-process/scratch/gpu0
GPU1_SCRATCH_HOST_PATH=/srv/gvhmr-batch-process/scratch/gpu1

# Worker runtime
GVHMR_BATCH_WORKER_RUNNER_BACKEND=real
GVHMR_BATCH_WORKER_RUNNER_ENTRY_MODULE=gvhmr_runner.bridge.demo_with_skeleton
GVHMR_BATCH_WORKER_RUNNER_TIMEOUT_SECONDS=3600
GVHMR_BATCH_WORKER_INFRA_RETRY_DELAY_SECONDS=30
GVHMR_BATCH_WORKER_JOB_POLL_INTERVAL_SECONDS=2
GVHMR_BATCH_WORKER_MODEL_ROOT=/app/gvhmr/inputs/checkpoints
GVHMR_BATCH_WORKER_GVHMR_ROOT=/app/gvhmr
GVHMR_BATCH_WORKER_SCRATCH_ROOT=/var/lib/gvhmr-batch-process
GVHMR_BATCH_WORKER_HEALTHCHECK_FILE=/tmp/gvhmr-batch-worker-health.json
GVHMR_BATCH_WORKER_HEALTHCHECK_MAX_AGE_SECONDS=30
GVHMR_BATCH_WORKER_IDENTITY_STALE_AFTER_SECONDS=30
GVHMR_BATCH_WORKER_CLOCK_SKEW_WARN_SECONDS=5
GVHMR_BATCH_WORKER_CLOCK_SKEW_FAIL_SECONDS=30
GVHMR_BATCH_WORKER_SCRATCH_MIN_FREE_BYTES=4294967296
GVHMR_BATCH_WORKER_SCRATCH_CLEANUP_INTERVAL_SECONDS=300
GVHMR_BATCH_WORKER_SCRATCH_SUCCESS_TTL_SECONDS=3600
GVHMR_BATCH_WORKER_SCRATCH_FAILED_TTL_SECONDS=604800
GVHMR_BATCH_WORKER_SCRATCH_ORPHAN_TTL_SECONDS=86400
GVHMR_BATCH_WORKER_UPSTREAM_GVHMR_REF=088caff492aa38c2d82cea363b78a3c65a83118f

# Control plane endpoints.
# Replace 10.0.0.10 with the control-plane host or DNS name.
GVHMR_BATCH_WORKER_POSTGRES_DSN=postgresql://postgres:postgres@10.0.0.10:15432/gvhmr_batch_process
GVHMR_BATCH_WORKER_REDIS_URL=redis://10.0.0.10:16379/0
GVHMR_BATCH_WORKER_MINIO_ENDPOINT=10.0.0.10:19000
GVHMR_BATCH_WORKER_MINIO_ACCESS_KEY=minioadmin
GVHMR_BATCH_WORKER_MINIO_SECRET_KEY=minioadmin
GVHMR_BATCH_WORKER_MINIO_BUCKET=gvhmr-batch-process
GVHMR_BATCH_WORKER_MINIO_SECURE=false
